{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"target": "es5",
		"module": "CommonJS",
		"resolveJsonModule": true,
		// the ESM pass performs type checking and declaration emit (package "types" fields point at dist/esm)
		"noCheck": true,
		"declaration": false,
		"declarationMap": false
	}
}